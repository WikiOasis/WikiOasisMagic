	"description": "WikiOasis messages, hooks and scripts.",
	"type": "mediawiki-extension",
	"license": "GPL-3.0-or-later",
	"require": {
		"aws/aws-sdk-php": "^3.67",
		"composer/installers": "^1 || ^2"
	},
	"extra": {
